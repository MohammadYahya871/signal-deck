<Window x:Class="SignalDeck.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:SignalDeck.Core.Models;assembly=SignalDeck.Core"
        Title="SignalDeck"
        Width="980"
        Height="640"
        MinWidth="880"
        MinHeight="560"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock FontSize="28" FontWeight="SemiBold" Text="SignalDeck" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#555"
                       Text="Create multiple playback rules for sign-in, return, app launch, lock, unlock, and resume events." />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="14" Background="#F6F7F8" CornerRadius="10">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Rules" />
                        <TextBlock Margin="0,4,0,0" Foreground="#666" Text="Each rule maps one sound to one trigger." />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Width="110" Height="34" Margin="0,0,10,0" Command="{Binding AddRuleCommand}" Content="Add Rule" />
                        <Button Width="120" Height="34" Command="{Binding RemoveRuleCommand}" Content="Remove Rule" />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Rules}" SelectedItem="{Binding SelectedRule}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Margin="0,0,0,8" Background="White" CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                        <TextBlock Margin="0,4,0,0" Foreground="#666" Text="{Binding TriggerSummary}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Padding="18" Background="#FCFCFC" CornerRadius="10" BorderBrush="#E5E5E5" BorderThickness="1">
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedRule}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,18">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Rule Details" />
                        <TextBlock Margin="0,4,0,0" Foreground="#666" Text="Fine-tune playback, trigger type, and cooldown behavior." />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Grid DataContext="{Binding SelectedRule}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,14,12" VerticalAlignment="Center" Text="Rule name" />
                            <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,14,12" VerticalAlignment="Center" Text="Audio file" />
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,12,12" Text="{Binding AudioFilePath, UpdateSourceTrigger=PropertyChanged}" />
                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                                <Button Width="90" Margin="0,0,0,8" Command="{Binding DataContext.BrowseAudioCommand, RelativeSource={RelativeSource AncestorType=Window}}" Content="Browse" />
                                <Button Width="90" Command="{Binding DataContext.PreviewAudioCommand, RelativeSource={RelativeSource AncestorType=Window}}" Content="Preview" />
                            </StackPanel>

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,14,12" VerticalAlignment="Center" Text="Output device" />
                            <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,0,12,12"
                                      DisplayMemberPath="Name"
                                      ItemsSource="{Binding DataContext.Devices, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedItem="{Binding SelectedDevice}" />
                            <Button Grid.Row="2" Grid.Column="2" Width="90" Margin="0,0,0,12" Command="{Binding DataContext.RefreshDevicesCommand, RelativeSource={RelativeSource AncestorType=Window}}" Content="Refresh" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,14,12" VerticalAlignment="Center" Text="Volume" />
                            <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12">
                                <Slider Minimum="0" Maximum="100" Value="{Binding VolumePercent}" />
                                <TextBlock Margin="0,4,0,0" Foreground="#666" Text="{Binding VolumePercent, StringFormat={}{0}%}" />
                            </StackPanel>

                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,14,12" VerticalAlignment="Center" Text="Trigger type" />
                            <ComboBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{Binding DataContext.TriggerTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedValuePath="Type"
                                      SelectedValue="{Binding TriggerType}" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,14,12" VerticalAlignment="Top" Text="Idle threshold" />
                            <StackPanel Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TriggerType}" Value="{x:Static models:TriggerType.ReturnAfterIdle}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBox Width="80" Text="{Binding IdleThresholdMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="8,4,0,0" Text="minutes" />
                            </StackPanel>

                            <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,0,14,12" VerticalAlignment="Top" Text="Watched apps" />
                            <StackPanel Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TriggerType}" Value="{x:Static models:TriggerType.AppLaunch}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBox MinHeight="90"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding AppProcessNamesText, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="#666"
                                           Text="Enter one executable per line, like chrome.exe or slack.exe." />
                            </StackPanel>

                            <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,0,14,12" VerticalAlignment="Center" Text="Cooldown" />
                            <StackPanel Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBox Width="80" Text="{Binding CooldownMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="8,4,0,0" Text="minutes (0 = off)" />
                            </StackPanel>

                            <CheckBox Grid.Row="8" Grid.Column="1" Margin="0,0,0,8" IsChecked="{Binding IsEnabled}" Content="Enable this rule" />
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,16,0,0">
            <CheckBox DockPanel.Dock="Right" Margin="14,0,0,0" IsChecked="{Binding LaunchAtSignIn}" Content="Launch at sign-in" />
            <Button DockPanel.Dock="Right" Width="120" Height="34" Command="{Binding SaveCommand}" Content="Save All" />
            <TextBlock VerticalAlignment="Center" Foreground="#555" Text="{Binding StatusMessage}" />
        </DockPanel>
    </Grid>
</Window>
