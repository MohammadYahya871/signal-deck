<Window x:Class="SignalDeck.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:SignalDeck.Core.Models;assembly=SignalDeck.Core"
        Title="SignalDeck"
        Width="1160"
        Height="760"
        MinWidth="1020"
        MinHeight="680"
        Background="#F3F6F8"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFDFD" />
        <SolidColorBrush x:Key="MutedBrush" Color="#66727F" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0F766E" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D6DDE3" />
        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#EAF0F3" />
            <Setter Property="Foreground" Value="#14323F" />
            <Setter Property="BorderBrush" Value="#D0D8DF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
        </Style>
        <Style TargetType="Button" x:Key="PrimaryButtonStyle" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Background="#16303A" BorderThickness="0" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="32" FontWeight="SemiBold" Foreground="White" Text="SignalDeck" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#C8D5DB"
                               Text="Shape return cues, startup greetings, app-launch sounds, and other Windows audio moments with reusable rules." />
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#234854"
                        CornerRadius="14"
                        Padding="14,10"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Foreground="#C8D5DB" Text="Session status" />
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="White" Text="{Binding StatusMessage}" TextWrapping="Wrap" Width="260" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Rules" />
                        <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}" Text="Each rule combines a sound, a target device, and a trigger." />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom" Margin="0,14,0,0">
                        <WrapPanel>
                            <Button Width="92" Height="36" Margin="0,0,8,8" Command="{Binding AddRuleCommand}" Content="Add" />
                            <Button Width="92" Height="36" Margin="0,0,8,8" Command="{Binding DuplicateRuleCommand}" Content="Duplicate" />
                            <Button Width="92" Height="36" Margin="0,0,0,8" Command="{Binding RemoveRuleCommand}" Content="Remove" />
                        </WrapPanel>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Rules}" SelectedItem="{Binding SelectedRule}" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="14"
                                        Background="#F6F9FB"
                                        BorderBrush="#D8E0E7"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" FontSize="15" Text="{Binding DisplayName}" />
                                        <TextBlock Margin="0,6,0,0" Foreground="#29414F" Text="{Binding TriggerSummary}" TextWrapping="Wrap" />
                                        <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}" Text="{Binding PlaybackSummary}" TextWrapping="Wrap" />
                                        <Border Margin="0,10,0,0"
                                                Padding="8,5"
                                                Background="#EEF4F7"
                                                BorderBrush="#D5E0E6"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <TextBlock Text="{Binding StatusText}" Foreground="#36505E" />
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedRule}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,18">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock FontSize="22" FontWeight="SemiBold" Text="Rule Studio" />
                            <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}" Text="Refine playback, trigger details, fallback behavior, and cooldowns." />
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Width="110" Height="38" Margin="0,0,10,0" Command="{Binding PreviewAudioCommand}" Content="Preview Audio" />
                            <Button Width="110" Height="38" Command="{Binding TestRuleCommand}" Content="Test Rule" Style="{StaticResource PrimaryButtonStyle}" />
                        </StackPanel>
                    </DockPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Grid DataContext="{Binding SelectedRule}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,14,12" VerticalAlignment="Center" Text="Rule name" />
                            <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12" Padding="10,6" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,14,12" VerticalAlignment="Center" Text="Audio file" />
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,12,12" Padding="10,6" Text="{Binding AudioFilePath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="1" Grid.Column="2" Width="90" Height="34" Margin="0,0,0,12" Command="{Binding DataContext.BrowseAudioCommand, RelativeSource={RelativeSource AncestorType=Window}}" Content="Browse" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,14,12" VerticalAlignment="Center" Text="Output device" />
                            <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,0,12,12"
                                      Padding="8,4"
                                      DisplayMemberPath="Name"
                                      ItemsSource="{Binding DataContext.Devices, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedItem="{Binding SelectedDevice}" />
                            <Button Grid.Row="2" Grid.Column="2" Width="90" Height="34" Margin="0,0,0,12" Command="{Binding DataContext.RefreshDevicesCommand, RelativeSource={RelativeSource AncestorType=Window}}" Content="Refresh" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,14,12" VerticalAlignment="Center" Text="If device is missing" />
                            <ComboBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12"
                                      Padding="8,4"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{Binding DataContext.DeviceFallbackOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedValuePath="Mode"
                                      SelectedValue="{Binding DeviceFallbackMode}" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,14,12" VerticalAlignment="Center" Text="Volume" />
                            <StackPanel Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12">
                                <Slider Minimum="0" Maximum="100" Value="{Binding VolumePercent}" />
                                <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}" Text="{Binding VolumePercent, StringFormat={}{0}%}" />
                            </StackPanel>

                            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,14,12" VerticalAlignment="Center" Text="Trigger type" />
                            <ComboBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12"
                                      Padding="8,4"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{Binding DataContext.TriggerTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedValuePath="Type"
                                      SelectedValue="{Binding TriggerType}" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,0,14,12" VerticalAlignment="Top" Text="Idle threshold" />
                            <StackPanel Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TriggerType}" Value="{x:Static models:TriggerType.ReturnAfterIdle}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBox Width="90" Padding="10,6" Text="{Binding IdleThresholdMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="10,7,0,0" Text="minutes" />
                            </StackPanel>

                            <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,0,14,12" VerticalAlignment="Top" Text="Watched apps" />
                            <StackPanel Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TriggerType}" Value="{x:Static models:TriggerType.AppLaunch}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBox MinHeight="90"
                                         Padding="10,8"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding AppProcessNamesText, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="Enter one executable per line, like chrome.exe or slack.exe." />
                            </StackPanel>

                            <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,0,14,12" VerticalAlignment="Center" Text="Cooldown" />
                            <StackPanel Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBox Width="90" Padding="10,6" Text="{Binding CooldownMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="10,7,0,0" Text="minutes (0 = off)" />
                            </StackPanel>

                            <Border Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="3" Background="#F5F8FA" BorderBrush="#D8E0E7" BorderThickness="1" CornerRadius="14" Padding="14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="Rule health" />
                                        <TextBlock Margin="0,6,0,0" Foreground="#29414F" Text="{Binding StatusText}" />
                                        <TextBlock Margin="0,6,0,0" Foreground="{StaticResource MutedBrush}" Text="{Binding PlaybackSummary}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" Margin="16,2,0,0" IsChecked="{Binding IsEnabled}" Content="Enable this rule" VerticalAlignment="Top" />
                                </Grid>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Recent Activity" />
                        <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}" Text="See what played, what was skipped, and why." />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding ActivityLogEntries}" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="#F6F9FB"
                                        BorderBrush="#D8E0E7"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding RuleName}" />
                                            <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding Timestamp}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,6,0,0" Text="{Binding Message}" TextWrapping="Wrap" Foreground="#314854" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,18,0,0" Padding="16">
            <DockPanel>
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Text="Save when you are happy with the rule set. Launch-at-sign-in stays enabled by default for a smoother experience." />
                <CheckBox DockPanel.Dock="Right" Margin="16,0,0,0" IsChecked="{Binding LaunchAtSignIn}" Content="Launch at sign-in" VerticalAlignment="Center" />
                <Button DockPanel.Dock="Right" Width="130" Height="38" Command="{Binding SaveCommand}" Content="Save All" Style="{StaticResource PrimaryButtonStyle}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
